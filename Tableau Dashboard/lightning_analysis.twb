      <aliases enabled='yes' />
      <column caption='Peak Month' datatype='string' name='[Calculation_0593198131281920]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED : MAX(&#13;&#10;    IF { FIXED DATENAME(&apos;month&apos;, [date]) : SUM([strikes]) } =&#13;&#10;       { FIXED : MAX({ FIXED DATENAME(&apos;month&apos;, [date]) : SUM([strikes]) }) }&#13;&#10;    THEN DATENAME(&apos;month&apos;, [date])&#13;&#10;    END&#13;&#10;)}' />
      </column>
      <column caption='Daily Total Strikes' datatype='integer' name='[Calculation_0593198155460611]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [date] : SUM([strikes])}' />
      </column>
      <column caption='Month Names' datatype='string' name='[Calculation_0761423817875456]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;, [date])' />
      </column>
      <column aggregation='Sum' caption='Week of Month' datatype='integer' name='[Calculation_0761424131432464]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&apos;week&apos;, [date]) - DATEPART(&apos;week&apos;, DATETRUNC(&apos;month&apos;, [date])) + 1' />
      </column>
      <column caption='Month Sort' datatype='integer' name='[Calculation_0761424169357330]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MONTH([date])' />
      </column>
      <column caption='Peak Day' datatype='integer' name='[Calculation_0876596925292545]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED: MAX({FIXED [date] : SUM([strikes])})}' />
      </column>
      <column caption='Peak Date' datatype='date' name='[Calculation_0876596927766530]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED : MAX(&#13;&#10;    IF { FIXED [date] : SUM([strikes]) } = &#13;&#10;       { FIXED : MAX({ FIXED [date] : SUM([strikes]) }) }&#13;&#10;    THEN [date]&#13;&#10;    END&#13;&#10;)}' />
      </column>
      <column caption='AVG Daily Totals' datatype='real' name='[Calculation_1755380873691136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED : AVG({ FIXED [date] : SUM([strikes])})}' />
      </column>
      <column caption='Year Label' datatype='string' name='[Calculation_2125094124281857]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF YEAR([date]) = 2009 THEN &quot;2009&quot;&#13;&#10;ELSEIF YEAR([date]) = 2012 THEN &quot;2012&quot;&#13;&#10;ELSEIF YEAR([date]) = 2015 THEN &quot;2015&quot;&#13;&#10;ELSEIF YEAR([date]) = 2018 THEN &quot;2018&quot;&#13;&#10;ELSE &quot;All years&quot;&#13;&#10;END' />
      </column>
      <column caption='Year Filter' datatype='boolean' name='[Calculation_2125094155268101]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1] = &quot;All years&quot; OR STR(YEAR([date])) = [Parameters].[Parameter 1]' />
      </column>
